{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "types": ["chrome"]
  },
  "include": ["src/**/*.js", "shared/**/*.js", "content/**/*.js", "pages/**/*.js"],
  "exclude": ["node_modules", "tests", "builds", "tmp"]
}
