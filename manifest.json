{
  "manifest_version": 3,
  "name": "Blockdoze",
  "version": "1.0",
  "key": "",
  "default_locale": "es",
  "description": "Bloqueá sitios que te distraen. Configurá días, timers y excepciones para mantener el foco.",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs",
    "windows"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "pages/popup/popup.html",
    "default_title": "Blockdoze",
    "default_icon": { "16": "icons/icon_16.png", "32": "icons/icon_32.png", "48": "icons/icon_48.png", "128": "icons/icon_128.png" }
  },
  "options_ui": {
    "page": "pages/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "web_accessible_resources": [{
    "resources": [
      "content/themes/bar/*.css",
      "content/themes/expiry/*.css",
      "content/templates/*.html",
      "assets/BlockDoze_Original.svg"
    ],
    "matches": ["<all_urls>"]
  }],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/timer-overlay.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}
