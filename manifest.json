{
  "manifest_version": 3,
  "name": "Site Blocker",
  "version": "1.0",
  "key": "",
  "description": "Bloquea sitios web que distraen",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Site Blocker"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["ytmusic.js"],
      "run_at": "document_idle"
    }
  ]
}
